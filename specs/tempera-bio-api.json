                  "$ref": "#/components/schemas/GoogleRpcErrorResponse"
                }
              }
            },
            "description": "The request failed closed validation."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoogleRpcErrorResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoogleRpcErrorResponse"
                }
              }
            },
            "description": "Required Bio scope denied."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoogleRpcErrorResponse"
                }
              }
            },
            "description": "Internal server error."
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoogleRpcErrorResponse"
                }
              }
            },
            "description": "Upstream Bio source unavailable."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Derive campaign state",
        "x-tempera-auth-audience": "tempera-bio",
        "x-tempera-effect": "derive_artifact",
        "x-tempera-physical-action": false,
        "x-tempera-required-scope": "bio:decision:write"
      }
