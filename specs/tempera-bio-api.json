{
  "components": {
    "schemas": {
      "ArtifactResponse": {
        "additionalProperties": false,
        "properties": {
          "result": {
            "properties": {
              "contentDigest": {
                "pattern": "^sha256:[a-f0-9]{64}$",
                "type": "string"
              },
              "schemaVersion": {
                "type": "string"
              }
            },
            "required": [
              "schemaVersion",
              "contentDigest"
            ],
            "type": "object"
          }
        },
        "required": [
          "result"
        ],
        "type": "object"
      },
      "CampaignRound": {
        "additionalProperties": false,
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "experimentProposal": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "verifierReceipts": {
            "items": {
              "$ref": "#/components/schemas/SealedArtifact"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "experimentProposal",
          "verifierReceipts",
          "decision"
        ],
        "type": "object"
      },
      "DeriveCampaignStateRequest": {
        "additionalProperties": false,
        "properties": {
          "candidateSet": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "hypothesis": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "program": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "rounds": {
            "items": {
              "$ref": "#/components/schemas/CampaignRound"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "program",
          "hypothesis",
          "candidateSet",
          "rounds"
        ],
        "type": "object"
      },
      "DeriveDecisionRequest": {
        "additionalProperties": false,
        "properties": {
          "candidateSet": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "experimentProposal": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "hypothesis": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "program": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "verifierReceipts": {
            "items": {
              "$ref": "#/components/schemas/SealedArtifact"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "program",
          "hypothesis",
          "candidateSet",
          "experimentProposal",
          "verifierReceipts"
        ],
        "type": "object"
      },
      "GoogleRpcErrorInfo": {
        "additionalProperties": false,
        "properties": {
          "@type": {
            "const": "type.googleapis.com/google.rpc.ErrorInfo",
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "@type",
          "reason",
          "domain",
          "metadata"
        ],
        "type": "object"
      },
      "GoogleRpcErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "error": {
            "$ref": "#/components/schemas/GoogleRpcStatus"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "GoogleRpcStatus": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "format": "int32",
            "type": "integer"
          },
          "details": {
            "items": {
              "$ref": "#/components/schemas/GoogleRpcErrorInfo"
            },
            "type": "array"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "status",
          "details"
        ],
        "type": "object"
      },
      "IdentitySignature": {
        "additionalProperties": false,
        "properties": {
          "algorithm": {
            "minLength": 1,
            "type": "string"
          },
          "keyId": {
            "minLength": 1,
            "type": "string"
          },
          "signature": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "algorithm",
          "keyId",
          "signature"
        ],
        "type": "object"
      },
      "IngestMaveDBScoreSetRequest": {
        "additionalProperties": false,
        "properties": {
          "scoreSetUrn": {
            "pattern": "^urn:mavedb:[0-9]{8}-(?:[a-z]+|0)-[1-9][0-9]*$",
            "type": "string"
          }
        },
        "required": [
          "scoreSetUrn"
        ],
        "type": "object"
      },
      "PrepareCandidateSetRequest": {
        "additionalProperties": false,
        "properties": {
          "candidates": {
            "items": {
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "candidates"
        ],
        "type": "object"
      },
      "PrepareDatasetReleaseManifestRequest": {
        "additionalProperties": false,
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "program": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "verifierReceipts": {
            "items": {
              "$ref": "#/components/schemas/SealedArtifact"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "program",
          "decision",
          "verifierReceipts"
        ],
        "type": "object"
      },
      "PrepareExperimentProposalRequest": {
        "additionalProperties": false,
        "properties": {
          "candidateSet": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "program": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "selectedCandidates": {
            "items": {
              "$ref": "#/components/schemas/SealedArtifact"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "program",
          "candidateSet",
          "selectedCandidates"
        ],
        "type": "object"
      },
      "PrepareHypothesisRequest": {
        "additionalProperties": false,
        "properties": {
          "hypothesis": {
            "type": "object"
          }
        },
        "required": [
          "hypothesis"
        ],
        "type": "object"
      },
      "PrepareProgramRequest": {
        "additionalProperties": false,
        "properties": {
          "candidateSet": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "configuration": {
            "type": "object"
          },
          "hypothesis": {
            "$ref": "#/components/schemas/SealedArtifact"
          }
        },
        "required": [
          "configuration",
          "hypothesis",
          "candidateSet"
        ],
        "type": "object"
      },
      "SealedArtifact": {
        "description": "LowerCamel REST projection of a sealed artifact. Exact closed internal schemas remain published in contracts/ and retain their canonical snake_case digest representation.",
        "properties": {
          "contentDigest": {
            "pattern": "^sha256:[a-f0-9]{64}$",
            "type": "string"
          },
          "schemaVersion": {
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "contentDigest"
        ],
        "type": "object"
      },
      "VerifyMeasurementRequest": {
        "additionalProperties": false,
        "properties": {
          "candidate": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "experimentProposal": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "hypothesis": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "identitySignature": {
            "$ref": "#/components/schemas/IdentitySignature"
          },
          "program": {
            "$ref": "#/components/schemas/SealedArtifact"
          },
          "rawMeasurementBase64": {
            "contentEncoding": "base64",
            "type": "string"
          }
        },
        "required": [
          "candidate",
          "program",
          "hypothesis",
          "experimentProposal",
          "rawMeasurementBase64",
          "identitySignature"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "Auth Hub access token or API key",
        "description": "Opaque bearer verified through the Auth Hub /v1/oauth/introspect endpoint.",
        "scheme": "bearer",
        "type": "http",
        "x-tempera-auth-audience": "tempera-bio",
        "x-tempera-scopes-supported": [
          "bio:decision:write",
          "bio:measurement:verify",
          "bio:proposal:write",
          "bio:source:read"
        ]
      }
    }
  },
  "info": {
    "description": "Phase-specific biological discovery derivation. This API does not persist releases or execute physical experiments.",
    "title": "Tempera Bio Discovery API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
