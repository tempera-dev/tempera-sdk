{
  "schema_version": 1,
  "service": "remi",
  "default_base_url": "http://127.0.0.1:8765",
  "contract_kind": "http-route-manifest",
  "source_of_truth": {
    "router": "crates/beater-memory/src/server.rs",
    "cli": "crates/beater-memory/src/bin/beater-memory.rs",
    "readme": "README.md"
  },
  "auth": {
    "scheme": "bearer",
    "header": "Authorization",
    "format": "Bearer <token>",
    "env": "BEATER_MEMORY_TOKEN",
    "notes": [
      "The serve command refuses to start without a bearer token unless --allow-no-auth is passed.",
      "All /v1 routes require the configured bearer when auth is enabled.",
      "/livez and /readyz are unauthenticated process and readiness probes."
    ]
  },
  "request_id": {
    "header": "x-request-id",
    "semantics": "Tracing and durable audit correlation only; this is not a replay or idempotency guarantee."
  },
  "error_shape": {
    "content_type": "application/json",
    "schema": "ErrorBody",
    "fields": [
      "error.code",
      "error.status",
      "error.message",
      "error.details"
    ],
    "field_types": {
      "error.code": "integer",
      "error.status": "string",
      "error.message": "string",
      "error.details": "array"
    },
    "detail_type": "google.rpc.ErrorInfo",
    "detail_domain": "remi.tempera.dev",
    "status_header_semantics": {
      "401": "WWW-Authenticate: Bearer",
      "429": "Retry-After",
      "503": "Retry-After",
      "504": "Retry-After"
    },
    "reasons": [
      "unauthorized",
      "rate_limited",
      "service_busy",
      "service_timeout",
      "bad_request",
      "internal_error"
    ],
    "statuses": [
      "INVALID_ARGUMENT",
      "UNAUTHENTICATED",
      "RESOURCE_EXHAUSTED",
      "INTERNAL",
      "UNAVAILABLE",
      "DEADLINE_EXCEEDED"
    ]
  },
  "endpoints": [
    {
      "operation": "livez",
      "method": "GET",
      "path": "/livez",
      "auth": "public",
      "response_schema": "LiveResponse",
      "response_fields": [
        "status"
      ]
    },
    {
      "operation": "readyz",
      "method": "GET",
      "path": "/readyz",
      "auth": "public",
      "response_schema": "ReadyResponse",
      "response_fields": [
        "status",
        "database",
        "message"
      ]
    },
    {
      "operation": "health",
      "method": "GET",
      "path": "/v1/health",
      "auth": "bearer",
      "response_schema": "StoreHealth",
      "response_fields": [
        "applicationId",
        "expectedApplicationId",
        "schemaVersion",
        "expectedSchemaVersion",
        "integrityOk",
        "integrityMessages",
        "foreignKeyViolations",
        "graphIntegrityOk",
        "graphIntegrity",
        "stats"
      ]
    },
    {
      "operation": "getStats",
      "method": "GET",
      "path": "/v1/stats",
      "auth": "bearer",
      "response_schema": "StoreStats",
      "response_fields": [
        "ledgerEvents",
        "pendingEvents",
        "nodes",
        "activeNodes",
        "edges",
        "auditEvents"
      ]
    },
    {
      "operation": "getMetrics",
      "method": "GET",
      "path": "/v1/metrics",
      "auth": "bearer",
      "response_schema": "ServiceMetricsSnapshot",
      "response_fields": [
        "startedAtUnixMs",
        "totalRequests",
        "authorizedRequests",
        "unauthorizedRequests",
        "rateLimitedRequests",
        "dbBusyRequests",
        "dbTimeoutRequests",
        "successfulRequests",
        "failedRequests",
        "liveRequests",
        "readyRequests",
        "healthRequests",
        "statsRequests",
        "rememberRequests",
        "projectRequests",
        "queryRequests",
        "maintenanceRequests",
        "metricsRequests",
        "auditRequests"
      ]
    },
    {
      "operation": "getPrometheusMetrics",
      "method": "GET",
      "path": "/v1/metrics/prometheus",
      "auth": "bearer",
      "response_schema": "PrometheusText"
    },
    {
      "operation": "listAudit",
      "method": "GET",
      "path": "/v1/audit",
      "auth": "bearer",
      "query_schema": "AuditHttpQuery",
      "query_fields": [
        "pageSize",
        "pageToken"
      ],
      "response_schema": "AuditHttpResponse",
      "response_fields": [
        "events",
        "nextPageToken"
      ]
    },
    {
      "operation": "remember",
      "method": "POST",
      "path": "/v1/remember",
      "auth": "bearer",
      "request_schema": "RememberHttpRequest",
      "request_fields": [
        "tenantId",
        "projectId",
        "environmentId",
        "kind",
        "text",
        "idempotencyKey",
        "project"
      ],
      "required_request_fields": [
        "tenantId",
        "projectId",
        "kind",
        "text"
      ],
      "response_schema": "RememberHttpResponse",
      "response_fields": [
        "ingested",
        "project"
      ],
      "idempotency_field": "idempotencyKey",
      "description": "Write one memory event into the tenant and project ledger."
    },
    {
      "operation": "project",
      "method": "POST",
      "path": "/v1/project",
      "auth": "bearer",
      "request_schema": "ProjectHttpRequest",
      "request_fields": [
        "limit"
      ],
      "required_request_fields": [],
      "response_schema": "ProjectReport",
      "response_fields": [
        "eventsSeen",
        "eventsProjected",
        "eventsSkipped",
        "memoriesAdded",
        "memoriesUpdated",
        "memoriesInvalidated",
        "memoriesNooped",
        "edgesAdded"
      ]
    },
    {
      "operation": "query",
      "method": "POST",
      "path": "/v1/query",
      "auth": "bearer",
      "request_schema": "QueryHttpRequest",
      "request_fields": [
        "question",
        "scope",
        "maxTokens",
        "requireFresh",
        "modes",
        "reconstructionMode",
        "maxReconstructionSteps",
        "maxReconstructionTokens"
      ],
      "required_request_fields": [
        "question",
        "scope"
      ],
      "response_schema": "MemoryAnswer",
      "response_fields": [
        "answer",
        "evidence",
        "citedSpans",
        "contradictions",
        "staleAssumptions",
        "suggestedNextQueries",
        "tokenEstimate",
        "tierUsed",
        "reconstruction"
      ],
      "description": "Answer a scoped memory question with evidence and reconstruction metadata."
    },
    {
      "operation": "maintenance",
      "method": "POST",
      "path": "/v1/maintenance",
      "auth": "bearer",
      "request_schema": "MaintenanceHttpRequest",
      "request_fields": [
        "vacuum",
        "repairOrphans",
        "pruneAuditBeforeUnixMs",
        "retainLatestAuditEvents"
      ],
      "required_request_fields": [],
      "response_schema": "MaintenanceReport",
      "response_fields": [
        "optimized",
        "walCheckpointBusy",
        "walCheckpointLogFrames",
        "walCheckpointCheckpointedFrames",
        "vacuumed",
        "repairedOrphans",
        "prunedAuditEvents",
        "graphIntegrityBefore",
        "graphIntegrityAfter",
        "graphRepair",
        "auditPrune"
      ]
    }
  ],
  "sdk": {
    "status": "producer_contract",
    "published_in": "tempera-dev/tempera-sdk",
    "surface": "surface.json operations.remi",
    "notes": [
      "The aggregate SDK must vendor this manifest from an immutable Remi main commit.",
      "Endpoint operation values are the generated SDK operation identities.",
      "Resource-oriented Google AIP migration remains producer-owned and must update the router, this manifest, and generated clients together."
    ]
  }
}
