{
  "openapi": "3.0.3",
  "info": {
    "title": "tempera-gym API",
    "version": "0.6.0",
    "description": "Authenticated task, verifier, episode, environment, trajectory, and synchronous rollout surface over the shared Tempera RL substrate. Hand-written; tests/test_service.py contains a drift gate that keeps the (method, path, operationId) triples in lockstep with src/tempera_gym/service.py ROUTES. Errors use the canonical Tempera envelope {\"error\": {code, message, status, retryable}}. Auth is a static bearer (TEMPERA_GYM_API_TOKEN) or a centrally introspected token with audience tempera-gym; reads require scope dataset:read, rollout execution requires eval:run.",
    "license": {
      "name": "Proprietary",
      "identifier": "LicenseRef-Proprietary"
    }
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8096",
      "description": "local development default (TEMPERA_GYM_HOST/TEMPERA_GYM_PORT)"
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "health.get",
        "summary": "Liveness probe (unauthenticated)",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is up",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "service",
                    "version"
                  ],
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    },
                    "service": {
                      "type": "string",
                      "enum": [
                        "tempera-gym"
                      ]
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/environments": {
      "get": {
        "operationId": "environments.list",
        "summary": "Built-in and boot-trusted versioned environment catalog",
        "responses": {
          "200": {
            "description": "Built-in pack environments plus trusted external definitions; unavailable exact adapter identities remain discoverable but fail closed at execution.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "pack",
                    "environments"
                  ],
                  "properties": {
                    "pack": {
                      "type": "object",
                      "required": [
                        "id",
                        "version",
                        "contract_version",
                        "external_catalog_digest"
                      ],
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        },
                        "contract_version": {
                          "type": "string",
                          "enum": [
                            "tempera.gym-pack/v1"
                          ]
                        },
                        "external_catalog_digest": {
                          "$ref": "#/components/schemas/Digest"
                        }
                      }
                    },
                    "environments": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Environment"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/v1/domains": {
      "get": {
        "operationId": "domains.list",
        "summary": "Domain capabilities represented in the versioned task catalog",
        "responses": {
          "200": {
            "description": "Content-addressed domain catalog",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "catalog_digest",
                    "domains"
                  ],
                  "properties": {
                    "catalog_digest": {
                      "$ref": "#/components/schemas/Digest"
                    },
                    "domains": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "id",
                          "task_count",
                          "families",
                          "risk_tiers"
                        ],
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "task_count": {
                            "type": "integer",
                            "minimum": 1
                          },
                          "families": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "risk_tiers": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/v1/tasks": {
      "get": {
        "operationId": "tasks.list",
        "summary": "List versioned task definitions without agent inputs",
        "parameters": [
          {
            "name": "domain",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "family",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task summaries; hidden grader bodies are never returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "catalog_digest",
                    "tasks"
                  ],
                  "properties": {
                    "catalog_digest": {
                      "$ref": "#/components/schemas/Digest"
                    },
                    "tasks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Task"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/v1/tasks/{task}": {
      "get": {
        "operationId": "tasks.get",
        "summary": "Get one immutable task definition including its agent-visible input",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskId"
          },
          {
            "$ref": "#/components/parameters/TaskVersion"
          }
        ],
        "responses": {
          "200": {
            "description": "Task definition with verifier identity, never grader content",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "task"
                  ],
                  "properties": {
                    "task": {
                      "$ref": "#/components/schemas/Task"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/v1/tasks/{task}:evaluate": {
      "post": {
        "operationId": "tasks.evaluate",
        "summary": "Deterministically verify one candidate without creating an episode",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskId"
          },
          {
            "$ref": "#/components/parameters/TaskVersion"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "candidate"
                ],
                "properties": {
                  "candidate": {
                    "type": "object",
                    "description": "Validated against the selected Task.action_schema."
                  },
                  "seed": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9223372036854775807,
                    "default": 0
                  },
                  "receipts": {
                    "type": "array",
                    "maxItems": 64,
                    "items": {
                      "$ref": "#/components/schemas/EvidenceReceipt"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hidden-verifier-safe deterministic result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "result"
                  ],
                  "properties": {
                    "result": {
                      "$ref": "#/components/schemas/VerifierResult"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "412": {
            "$ref": "#/components/responses/FailedPrecondition"
          }
        }
      }
    },
    "/v1/verifiers": {
      "get": {
        "operationId": "verifiers.list",
        "summary": "List verifier identities and bound tasks without grader content",
        "responses": {
          "200": {
            "description": "Immutable verifier references",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "verifiers"
                  ],
                  "properties": {
                    "verifiers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/VerifierIdentity"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/v1/episodes": {
      "get": {
        "operationId": "episodes.list",
        "summary": "List durable episode snapshots, newest first",
        "parameters": [
          {
            "name": "domain",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "ACTIVE",
                "COMPLETED"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000,
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Episode snapshots",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "episodes"
                  ],
                  "properties": {
                    "episodes": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Episode"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "operationId": "episodes.create",
        "summary": "Reset a versioned task into a durable episode",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "task",
                  "seed"
                ],
                "properties": {
                  "task": {
                    "type": "string",
                    "description": "Task id or immutable id@semantic-version reference."
                  },
                  "seed": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9223372036854775807
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Active episode whose observation is the agent-safe task view",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "episode"
                  ],
                  "properties": {
                    "episode": {
                      "$ref": "#/components/schemas/Episode"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "412": {
            "$ref": "#/components/responses/FailedPrecondition"
          }
        }
      }
    },
    "/v1/episodes/{episode}": {
      "get": {
        "operationId": "episodes.get",
        "summary": "Read and content-verify one durable episode snapshot",
        "parameters": [
          {
            "$ref": "#/components/parameters/EpisodeId"
          }
        ],
        "responses": {
          "200": {
            "description": "Episode snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "episode"
                  ],
                  "properties": {
                    "episode": {
                      "$ref": "#/components/schemas/Episode"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/v1/episodes/{episode}:step": {
      "post": {
        "operationId": "episodes.step",
        "summary": "Apply one schema-validated action and persist the transition",
        "parameters": [
          {
            "$ref": "#/components/parameters/EpisodeId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "action"
                ],
                "properties": {
                  "action": {
                    "type": "object",
                    "description": "Validated against the episode Task.action_schema."
                  },
                  "receipts": {
                    "type": "array",
                    "maxItems": 64,
                    "items": {
                      "$ref": "#/components/schemas/EvidenceReceipt"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Completed transition, verifier result, and trajectory projection",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "episode",
                    "transition",
                    "verifier_result",
                    "trajectory"
                  ],
                  "properties": {
                    "episode": {
                      "$ref": "#/components/schemas/Episode"
                    },
                    "transition": {
                      "$ref": "#/components/schemas/Transition"
                    },
                    "verifier_result": {
                      "$ref": "#/components/schemas/VerifierResult"
                    },
                    "trajectory": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "412": {
            "$ref": "#/components/responses/FailedPrecondition"
          }
        }
      }
    },
    "/v1/episodes/{episode}:export": {
      "post": {
        "operationId": "episodes.export",
        "summary": "Retain a completed Gym episode and trajectory in Data Engine",
        "description": "Requires configured Data Engine service credentials. The context EvidenceRecord and PASS verifier receipt artifact must already exist in the configured project. Centrally authenticated callers require both eval:run and dataset:write.",
        "parameters": [
          {
            "$ref": "#/components/parameters/EpisodeId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "context_evidence_ref"
                ],
                "properties": {
                  "context_evidence_ref": {
                    "type": "string",
                    "pattern": "^projects/[^/]+/evidenceRecords/[a-f0-9]{64}$"
                  },
                  "verifier_receipt_artifact_ref": {
                    "type": "string",
                    "pattern": "^projects/[^/]+/artifacts/[^/]+$"
                  },
                  "request_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Data Engine episode plus completed trajectory ingest operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "episode",
                    "trajectory_operation"
                  ],
                  "properties": {
                    "episode": {
                      "type": "object",
                      "description": "data-engine.episode.v1 immutable resource"
                    },
                    "trajectory_operation": {
                      "$ref": "#/components/schemas/Operation"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "412": {
            "$ref": "#/components/responses/FailedPrecondition"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/v1/runs": {
      "get": {
        "operationId": "runs.list",
        "summary": "Persisted-run index, newest first",
        "parameters": [
          {
            "name": "environment_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Index records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "runs"
                  ],
                  "properties": {
                    "runs": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/RunRecord"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "412": {
            "$ref": "#/components/responses/FailedPrecondition"
          }
        }
      }
    },
    "/v1/runs/{run}": {
      "get": {
        "operationId": "runs.get",
        "summary": "Full trajectory envelope (incl. metadata.timing) for one run",
        "parameters": [
          {
            "name": "run",
            "in": "path",
            "required": true,
            "description": "run_id (uuid) or trajectory content_hash (sha256 hex)",
            "schema": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._~-]{1,256}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Index record + verified trajectory-v1 envelope",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "run",
                    "trajectory"
                  ],
                  "properties": {
                    "run": {
                      "$ref": "#/components/schemas/RunRecord"
                    },
                    "trajectory": {
                      "type": "object",
                      "description": "trajectory-v1 envelope (see contracts/trajectory-v1.schema.json)"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/DataLoss"
          }
        }
      }
    },
    "/v1/rollouts": {
      "post": {
        "operationId": "rollouts.create",
        "summary": "Execute one rollout synchronously, store it, return the summary",
        "requestBody": {
          "required": true,
          "description": "JSON request body; rejected when Content-Length exceeds 1 MiB.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "environment_id",
                  "seed"
                ],
                "additionalProperties": false,
                "properties": {
                  "environment_id": {
                    "type": "string",
                    "description": "Built-in id or trusted external id, optionally pinned as id@semantic-version."
                  },
                  "policy": {
                    "type": "string",
                    "enum": [
                      "random",
                      "llm"
                    ],
                    "default": "random"
                  },
                  "seed": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "max_steps": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Capped by the environment's manifest max_steps."
                  },
                  "model": {
                    "type": "string",
                    "default": "gpt-4o-mini",
                    "description": "tempera-llm model id; only used when policy is llm."
                  },
                  "data_engine_product_id": {
                    "type": "string",
                    "description": "Data Engine product id for a manifest-bound PUBLIC Risk RLVR rollout. Only valid with risk-normalization-verification-v1; the service project and credentials are deployment config. Centrally introspected callers need dataset:read and eval:run, plus org/project/environment/sub claims bound to that config."
                  },
                  "data_engine_max_records": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 256,
                    "default": 256
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Completed operation envelope (same shape data-engine returns)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Operation"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidArgument"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "412": {
            "$ref": "#/components/responses/FailedPrecondition"
          },
          "413": {
            "$ref": "#/components/responses/PayloadTooLarge"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "TaskId": {
        "name": "task",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9.-]{2,127}$"
        }
      },
      "TaskVersion": {
        "name": "version",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "EpisodeId": {
        "name": "episode",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Digest": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "EvidenceReceipt": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "kind",
          "digest"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "enum": [
              "tempera.gym.evidence-receipt/v1"
            ]
          },
          "kind": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "digest": {
            "$ref": "#/components/schemas/Digest"
          },
          "ref": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "VerifierBinding": {
        "type": "object",
        "required": [
          "kind",
          "ref",
          "hidden",
          "required_receipts",
          "digest"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "builtin",
              "cradle",
              "data-engine",
              "external"
            ]
          },
          "ref": {
            "type": "string"
          },
          "hidden": {
            "type": "boolean"
          },
          "required_receipts": {
            "type": "array",
            "maxItems": 16,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "digest": {
            "$ref": "#/components/schemas/Digest"
          }
        }
      },
      "VerifierIdentity": {
        "allOf": [
          {
            "$ref": "#/components/schemas/VerifierBinding"
          },
          {
            "type": "object",
            "required": [
              "available",
              "tasks"
            ],
            "properties": {
              "available": {
                "type": "boolean"
              },
              "tasks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "Task": {
        "type": "object",
        "required": [
          "schema_version",
          "name",
          "id",
          "version",
          "domain",
          "family",
          "title",
          "description",
          "environment",
          "action_schema",
          "verifier",
          "reward",
          "safety",
          "provenance",
          "task_digest"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "enum": [
              "tempera.gym.task/v1"
            ]
          },
          "name": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "agent_input": {
            "type": "object",
            "description": "Present on get; omitted from collection responses."
          },
          "environment": {
            "type": "object"
          },
          "action_schema": {
            "type": "object"
          },
          "verifier": {
            "$ref": "#/components/schemas/VerifierBinding"
          },
          "reward": {
            "type": "object"
          },
          "safety": {
            "type": "object"
          },
          "provenance": {
            "type": "object"
          },
          "task_digest": {
            "$ref": "#/components/schemas/Digest"
          }
        }
      },
      "CheckResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "passed",
          "score",
          "diagnostic"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "diagnostic": {
            "type": "string"
          }
        }
      },
      "VerifierResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "task",
          "task_digest",
          "verifier",
          "status",
          "score",
          "components",
          "checks",
          "evidence_receipts",
          "content_hash"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "enum": [
              "tempera.gym.verifier-result/v1"
            ]
          },
          "task": {
            "type": "string"
          },
          "task_digest": {
            "$ref": "#/components/schemas/Digest"
          },
          "verifier": {
            "type": "object",
            "required": [
              "kind",
              "ref",
              "digest"
            ],
            "properties": {
              "kind": {
                "type": "string"
              },
              "ref": {
                "type": "string"
              },
              "digest": {
                "$ref": "#/components/schemas/Digest"
              }
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "FAIL"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "components": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "checks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CheckResult"
            }
          },
          "evidence_receipts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EvidenceReceipt"
            }
          },
          "content_hash": {
            "$ref": "#/components/schemas/Digest"
          }
        }
      },
      "Transition": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "index",
          "observation",
          "action",
          "next_observation",
          "reward",
          "terminated",
          "truncated",
          "info"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "enum": [
              "tempera.gym.transition/v1"
            ]
          },
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "observation": {},
          "action": {},
          "next_observation": {},
          "reward": {
            "type": "number"
          },
          "terminated": {
            "type": "boolean"
          },
          "truncated": {
            "type": "boolean"
          },
          "info": {
            "type": "object"
          }
        }
      },
      "Episode": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "name",
          "task",
          "task_digest",
          "domain",
          "seed",
          "status",
          "step_count",
          "observation",
          "terminated",
          "truncated",
          "verifier_result",
          "trajectory_content_hash",
          "last_transition",
          "created_at",
          "updated_at",
          "content_hash"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "enum": [
              "tempera.gym.episode/v1"
            ]
          },
          "name": {
            "type": "string"
          },
          "task": {
            "type": "string"
          },
          "task_digest": {
            "$ref": "#/components/schemas/Digest"
          },
          "domain": {
            "type": "string"
          },
          "seed": {
            "type": "integer",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "COMPLETED"
            ]
          },
          "step_count": {
            "type": "integer",
            "minimum": 0
          },
          "observation": {},
          "terminated": {
            "type": "boolean"
          },
          "truncated": {
            "type": "boolean"
          },
          "verifier_result": {
            "type": "object",
            "nullable": true
          },
          "trajectory_content_hash": {
            "type": "string",
            "nullable": true,
            "pattern": "^[a-f0-9]{64}$"
          },
          "last_transition": {
            "type": "object",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "content_hash": {
            "$ref": "#/components/schemas/Digest"
          }
        }
      },
      "Environment": {
        "type": "object",
        "description": "One built-in pack entry or one resolved tempera.gym.environment/v1 definition. External definitions carry an immutable environment_digest and exact adapter identity.",
        "required": [
          "id",
          "version",
          "source",
          "available",
          "deterministic",
          "max_steps"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "builtin",
              "trusted_catalog"
            ]
          },
          "available": {
            "type": "boolean"
          },
          "schema_version": {
            "type": "string",
            "enum": [
              "tempera.gym.environment/v1"
            ]
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "instructions": {
            "type": "string"
          },
          "library": {
            "type": "string"
          },
          "task_family": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "deterministic": {
            "type": "boolean"
          },
          "network": {
            "type": "boolean"
          },
          "max_steps": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "implemented",
              "planned"
            ]
          },
          "environment_digest": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Digest"
              }
            ],
            "nullable": true
          },
          "image_digest": {
            "type": "string",
            "nullable": true
          },
          "resource_limits": {
            "type": "object",
            "nullable": true
          },
          "observation_schema": {
            "type": "object",
            "nullable": true
          },
          "action_schema": {
            "type": "object",
            "nullable": true
          },
          "info_schema": {
            "type": "object",
            "nullable": true
          },
          "action_space": {
            "type": "object",
            "nullable": true
          },
          "safety": {
            "type": "object",
            "nullable": true
          },
          "adapter": {
            "type": "object",
            "nullable": true
          },
          "provenance": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "RunRecord": {
        "type": "object",
        "description": "Index record enriched with server-side verification state. `verify` reports the store's content-hash re-derivation for the record's envelope (verification canonicalization lives server-side; clients must not re-implement it). The summary fields (steps, total_reward, terminal_reason, duration_ms) are present only when verify is \"verified\"; a tampered or missing envelope marks the record instead of failing the listing.",
        "required": [
          "run_id",
          "environment_id",
          "seed",
          "created_at",
          "content_hash",
          "policy",
          "verify"
        ],
        "properties": {
          "run_id": {
            "type": "string"
          },
          "environment_id": {
            "type": "string"
          },
          "seed": {
            "type": "integer"
          },
          "created_at": {
            "type": "string"
          },
          "content_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "policy": {
            "type": "string"
          },
          "verify": {
            "type": "string",
            "enum": [
              "verified",
              "integrity_failed",
              "missing"
            ]
          },
          "steps": {
            "type": "integer"
          },
          "total_reward": {
            "type": "number"
          },
          "terminal_reason": {
            "type": "string",
            "nullable": true
          },
          "duration_ms": {
            "type": "number",
            "nullable": true
          }
        }
      },
      "Operation": {
        "type": "object",
        "required": [
          "name",
          "done"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "done": {
            "type": "boolean"
          },
          "response": {
            "type": "object",
            "additionalProperties": true
          },
          "metadata": {
            "type": "object",
            "properties": {
              "target_resource": {
                "type": "string"
              },
              "create_time": {
                "type": "string"
              },
              "progress_ratio": {
                "type": "number"
              },
              "current_stage": {
                "type": "string"
              }
            }
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "required": [
          "code",
          "message",
          "status",
          "retryable"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "retryable": {
            "type": "boolean"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        }
      }
    },
    "responses": {
      "Unauthenticated": {
        "description": "Missing or invalid bearer token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Wrong audience or missing scope",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InvalidArgument": {
        "description": "Malformed request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Unknown route, environment, or run",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "FailedPrecondition": {
        "description": "Planned environment or unconfigured data directory",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Episode is complete or was stepped concurrently",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "PayloadTooLarge": {
        "description": "Request body over the bound",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unavailable": {
        "description": "Upstream (LLM gateway or introspection) failed closed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "DataLoss": {
        "description": "Stored envelope failed content-hash verification",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
