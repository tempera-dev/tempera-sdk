        "operationId": "workflows.create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowDefinition"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
