{
  "openapi": "3.0.3",
  "info": {
    "title": "Tempera Workflows API",
    "description": "Deterministic workflow engine for the Tempera ecosystem: bounded-DAG workflows (tempera.workflow/v1) of typed nodes — native orchestration nodes plus sdk.<product>.<opId> nodes generated from the tempera-sdk surface — executed as replayable, event-streamed runs. Thin orchestrator: code runs in cradle, LLM calls go through tempera-llm, data operations through data-engine.",
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Liveness. Unauthenticated.",
        "operationId": "healthz",
        "responses": {
          "200": {
            "description": "Service is live",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/node-types": {
      "get": {
        "tags": [
          "nodeTypes"
        ],
        "summary": "The studio palette: every node type with config JSON Schema and outputs.",
        "operationId": "nodeTypes.list",
        "responses": {
          "200": {
            "description": "Node type catalog (native + sdk.* nodes)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NodeTypeList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Missing scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/runs": {
      "get": {
        "tags": [
          "runs"
        ],
        "summary": "List runs, newest first.",
        "operationId": "runs.list",
        "parameters": [
          {
            "name": "workflowId",
            "in": "query",
            "description": "Filter by workflow id.",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum entries to return (default 100, max 500).",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Run summaries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Missing scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/runs/{runId}": {
      "get": {
        "tags": [
          "runs"
        ],
        "summary": "Full run view: status, per-node states with outputs/logs/metrics, timestamps.",
        "operationId": "runs.get",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "description": "Run id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The run",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Run"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Missing scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/runs/{runId}/events": {
      "get": {
        "tags": [
          "runs"
        ],
        "summary": "Server-sent events for a run: replays history from `?since=seq`, then",
        "description": "streams live `run.state` / `node.state` / `node.log` events until the run\nreaches a terminal state. SSE `id` = seq, `event` = type.",
        "operationId": "runs.events",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "description": "Run id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "since",
            "in": "query",
            "description": "Replay events with seq greater than this (default 0 = from the start).",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "text/event-stream of RunEvent payloads",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Missing scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/runs/{runId}:cancel": {
      "post": {
        "tags": [
          "runs"
        ],
        "summary": "Cancel a queued/running run. Already-cancelled runs return 200",
        "description": "(idempotent); other terminal states return 409.",
        "operationId": "runs.cancel",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "description": "Run id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Run already cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Run"
                }
              }
            }
          },
          "202": {
            "description": "Cancellation requested; poll runs.get",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Run"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Missing scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Run already finished",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/workflows": {
      "get": {
        "tags": [
          "workflows"
        ],
        "summary": "List workflows.",
        "operationId": "workflows.list",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum entries to return (default 100, max 500).",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true,
