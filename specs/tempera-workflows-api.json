            "description": "Workflow id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowDefinition"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated",
